# --- Required ---
# Postgres (Neon recommended). A local Postgres URL also works for development.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# Auth.js secret — generate with: npx auth secret
AUTH_SECRET=""

# --- Optional ---
# Google OAuth (required for "Sign in with Google"). Create at https://console.cloud.google.com
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Resend (transactional email). When unset, action links are logged to the server console.
RESEND_API_KEY=""
EMAIL_FROM="Cadence <onboarding@resend.dev>"
# Public base URL of the app (used in email + webhook links + OG metadata).
APP_URL="http://localhost:3000"
# Redis (BullMQ execution engine). Local: a Docker Redis; prod: Upstash (rediss://...).
# Required to run/execute workflows; the worker (npm run worker) also reads this.
REDIS_URL="redis://localhost:6379"
# Encryption key for stored Connection credentials. Generate: openssl rand -base64 32
# Required for the Connections feature; without it, Connections are disabled.
ENCRYPTION_KEY=""

# --- Billing (Stripe; optional — without these everyone stays on the free Starter plan) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Run `npm run stripe:setup` to create products/prices and print these IDs:
STRIPE_PRICE_TEAM_MONTHLY=""
STRIPE_PRICE_TEAM_ANNUAL=""
STRIPE_PRICE_SCALE_MONTHLY=""
STRIPE_PRICE_SCALE_ANNUAL=""
