# --- Required ---
# Postgres (Neon recommended). A local Postgres URL also works for development.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# Auth.js secret — generate with: npx auth secret
AUTH_SECRET=""

# --- Optional ---
# Google OAuth (required for "Sign in with Google"). Create at https://console.cloud.google.com
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Resend (transactional email). When unset, action links are logged to the server console.
RESEND_API_KEY=""
EMAIL_FROM="Cadence <onboarding@resend.dev>"
# Public base URL of the app (used in email + webhook links + OG metadata).
APP_URL="http://localhost:3000"
# Redis (BullMQ execution engine). Local: a Docker Redis; prod: Upstash (rediss://...).
# Required to run/execute workflows; the worker (npm run worker) also reads this.
REDIS_URL="redis://localhost:6379"
